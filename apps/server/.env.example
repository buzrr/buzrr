# HTTP + Socket.IO (same port). Match NEXT_PUBLIC_SOCKET_URL in apps/web (scheme + host + port only; no /api).
API_PORT=3001
# Or use PORT; API_PORT takes precedence in main.ts

# CORS for REST and Socket.IO browser clients (Next.js dev server or production URL).
# Comma-separated for multiple origins. Omit or empty = allow all in dev-friendly mode.
WEB_ORIGIN=http://localhost:3000

DATABASE_URL=""
DIRECT_URL=""

# Same secret as NextAuth (apps/web) for JWT-issued API tokens
NEXTAUTH_SECRET=""

# Upstash (optional; rate limiting)
UPSTASH_REDIS_URL=""
UPSTASH_REDIS_TOKEN=""

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
